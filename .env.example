# Copy to .env and adjust values
# Local testing defaults are fine as-is for most setups

# User/group ID — must match owner of library and ingest folders
# Find yours: id $(whoami)
PUID=1000
PGID=1000

# Your timezone
TZ=America/Phoenix

# Port to expose CWA on (default 8083)
PORT=8083

# Current CWA admin password — used by setup_cwa.py as the current credential
# After --rotate-password runs successfully, this is updated automatically
ADMIN_PASSWORD=

# Optional: set a specific password to rotate to via --rotate-password
# Cleared in .env after a successful rotation (when user confirms or --yes is passed)
ADMIN_REFRESH_PASSWORD=
