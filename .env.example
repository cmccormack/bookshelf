# Copy to .env and adjust values
# Local testing defaults are fine as-is for most setups

# User/group ID — must match owner of library and ingest folders
# Find yours: id $(whoami)
PUID=1000
PGID=1000

# Your timezone
TZ=America/Phoenix

# Port to expose CWA on (default 8083)
PORT=8083

# Current CWA admin password — used by setup_cwa.py to log in when rotating
# Update this after running --rotate-password or --update-password
ADMIN_PASSWORD=
